# Auto detect text files and perform LF normalization
*          text=auto

# Scripts
*.bash     text eol=lf
*.fish     text eol=lf
*.sh       text eol=lf
*.zsh      text eol=lf

# These are explicitly Windows files and should use CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Serialization and configuration
*.json     text eol=lf
*.toml     text eol=lf
*.xml      text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.properties text eol=lf

# Archives
*.7z       binary
*.gz       binary
*.tar      binary
*.tgz      binary
*.zip      binary
*.xz       binary
*.zstd     binary

# Text files where line endings should be preserved
*.patch    -text

# Exclude repository metadata from archive export
.gitattributes export-ignore
.gitignore     export-ignore
.gitkeep       export-ignore
.gitconfig     export-ignore

# Documents
*.md       text diff=markdown
*.mdx      text diff=markdown
*.adoc     text
*.csv      text
*.tab      text
*.tsv      text
*.txt      text
*.sql      text

# Binary documents and media
*.doc      binary
*.docx     binary
*.odt      binary
*.ods      binary
*.pdf      binary
*.vsd      binary
*.vsdx     binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary

# Common documentation
AUTHORS           text
CHANGELOG         text
CHANGES           text
CONTRIBUTING      text
COPYING           text
copyright         text
*COPYRIGHT*       text
INSTALL           text
license           text
LICENSE           text
NEWS              text
readme            text
*README*          text
TODO              text

# JVM sources and build files
*.java          text diff=java
*.kt            text diff=kotlin
*.groovy        text diff=java
*.scala         text diff=java
*.gradle        text diff=java
*.gradle.kts    text diff=kotlin
*.toml          text diff=toml

# Web and script sources
*.js            text
*.jsx           text
*.ts            text
*.tsx           text
*.css           text diff=css
*.scss          text diff=css
*.sass          text
*.htm           text diff=html
*.html          text diff=html
*.xhtml         text diff=html
*.svg           text

# These files are binary and should be left untouched
*.class         binary
*.dll           binary
*.ear           binary
*.jar           binary
*.so            binary
*.war           binary
*.jks           binary

# Common build-tool wrapper scripts
mvnw            text eol=lf
gradlew         text eol=lf
package.json    text eol=lf

*.lock          text -diff
package-lock.json text eol=lf -diff
yarn.lock       text -diff
